{
  "description": "AgentLab policy enforcement: MCP allowlist, PII masking, write-class consent. Reads policies/{pii,access}.md heuristics; consults the workspace .agentlab/context.json for the registered allowlist.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-hydrate.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-hydrate.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/policy-check.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
