{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlab/context.schema.json",
  "title": "AgentLab context.json (registrations only)",
  "description": "Workspace allowlist for datalakes and catalogs. Notebook memory (findings, hypotheses, preferences, …) lives in the AgentLab notebook store — use notebook.load / notebook.patch via the memory-superagents MCP adapter.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "context_version": {
      "type": "integer",
      "minimum": 1,
      "default": 3
    },
    "use_case": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "description",
            "domain",
            "domain_context",
            "activated_at"
          ],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "description": { "type": "string" },
            "domain": { "type": "string" },
            "domain_context": { "type": "object" },
            "activated_at": {
              "type": "string",
              "format": "date-time"
            },
            "updated_at": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      ]
    },
    "data_sources": {
      "type": "array",
      "description": "Registered datalake MCP backends (execute queries/code).",
      "items": { "$ref": "#/$defs/datalake" }
    },
    "catalogs": {
      "type": "array",
      "description": "Registered catalog MCP backends (retrieve semantics).",
      "items": { "$ref": "#/$defs/catalog" }
    }
  },
  "required": ["context_version", "use_case", "data_sources", "catalogs"],
  "$defs": {
    "datalake": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "exec_paradigm",
        "mcp_server",
        "purpose",
        "tags"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "const": "datalake" },
        "exec_paradigm": {
          "type": "string",
          "minLength": 1,
          "description": "e.g. sql, promql, cypher, mql, logs, document, graph"
        },
        "mcp_server": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "schema_summary": { "$ref": "#/$defs/schemaSummary" }
      }
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "mcp_server", "purpose", "tags"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "const": "catalog" },
        "retrieval": {
          "type": "string",
          "description": "e.g. vector, fts, structured"
        },
        "mcp_server": { "type": "string", "minLength": 1 },
        "scope": { "type": "string" },
        "purpose": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "schemaSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tables", "last_updated"],
      "properties": {
        "tables": {
          "type": "array",
          "items": { "$ref": "#/$defs/tableSummary" }
        },
        "last_updated": {
          "type": "string",
          "format": "date-time"
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "tableSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "fields", "row_estimate", "sample_values"],
      "properties": {
        "name": { "type": "string" },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "type"],
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" }
            }
          }
        },
        "row_estimate": {
          "type": "integer",
          "minimum": 0
        },
        "sample_values": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
